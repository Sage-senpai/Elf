# =============================================================================
# Elf — environment example
# Copy to .env.local and fill in. Never commit .env or .env.local.
# Defaults below assume testnet for all on-chain integrations.
# =============================================================================

# -- App --------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# -- Database (Supabase Postgres) ------------------------------------------
# Get from Supabase project settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@localhost:5432/elf
DIRECT_URL=postgresql://postgres:password@localhost:5432/elf

# Supabase client (used for storage + auth helpers later)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=elf-attachments

# -- Cache + queues --------------------------------------------------------
REDIS_URL=

# -- Auth (Better Auth) ----------------------------------------------------
# 32-byte hex; generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public origin Better Auth uses to construct callback + magic-link URLs.
# Must match NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app — create at https://github.com/settings/developers
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -- Encryption (AES-256 for stored GitHub tokens) -------------------------
# 32-byte hex; generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# -- AI: Anthropic (primary) -----------------------------------------------
# Default model for Cowork. Premium upgrade path: claude-opus-4-7
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# -- Email -----------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=noreply@elf.so

# -- Web2 payments ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -- Analytics + monitoring ------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# OpenAgents hackathon partners (sponsor integrations)
# =============================================================================

# -- 0G Network (storage + compute) ----------------------------------------
# Real packages: @0glabs/0g-ts-sdk, @0glabs/0g-serving-broker
# Defaults point to TESTNET. Switch to mainnet RPC for production.
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_KV_RPC=http://3.101.147.150:6789
ZG_CHAIN_ID=16601
ZG_PRIVATE_KEY=
ZG_STREAM_ID=
# Address of the deployed ShelfAgentStateManager (see contracts/README.md).
# When unset the Shelf Agent still runs and writes the local + 0G Log
# entries; only the on-chain anchor is skipped.
SHELF_AGENT_CONTRACT_ADDRESS=

# -- Gensyn AXL (P2P agent messaging) --------------------------------------
# Transport: 'mock' (Windows dev), 'binary' (Linux/macOS/WSL2 with axl installed)
AXL_TRANSPORT=mock
AXL_BINARY_PATH=/usr/local/bin/axl
AXL_CONFIG_PATH=./axl.config.json
AXL_BASE_PORT=9000

# -- KeeperHub (guaranteed execution) --------------------------------------
# No npm SDK yet — REST + MCP. Endpoints to confirm via sponsor Discord.
KEEPERHUB_API_KEY=
KEEPERHUB_API_URL=https://api.keeperhub.com
KEEPERHUB_MCP_URL=https://mcp.keeperhub.com
KEEPERHUB_WALLET_ADDRESS=

# -- x402 (autonomous agent payments) --------------------------------------
# Real package: x402-fetch (NOT @x402/fetch)
X402_FACILITATOR_URL=https://x402.coinbase.com/facilitate

# -- Uniswap (treasury swaps + contributor payments) -----------------------
# Trading API: https://docs.uniswap.org/api/trading/overview
# Get x-api-key from developers.uniswap.org
UNISWAP_API_KEY=
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org
# 84532 = Base Sepolia (testnet) | 8453 = Base mainnet
UNISWAP_CHAIN_ID=84532

# -- On-chain wallets (server-side only — NEVER expose to client) ----------
TREASURY_MASTER_WALLET_PRIVATE_KEY=
AGENT_WALLET_PRIVATE_KEY=
